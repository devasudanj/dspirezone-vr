# Environment configuration for Dspire VR Zone backend
# Copy to .env and fill in real values

# SQLite database path (on Azure server)
DATABASE_URL=sqlite:////home/data/dspirezone.db

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_GAMES=game-media

# Server settings
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS allowed origins (comma-separated)
CORS_ORIGINS=*
